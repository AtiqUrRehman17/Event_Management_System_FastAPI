# ============================================
# EVENT MANAGEMENT SYSTEM - ENVIRONMENT SETUP
# ============================================
# Quick start:
#   1. Copy this file to .env    (or just run: python setup.py)
#   2. Generate a SECRET_KEY:     python -c "import secrets; print(secrets.token_urlsafe(32))"
#   3. Start the app:             python run.py
#
# For email features, update the SMTP section with your Gmail App Password.
# For OAuth login, fill in the Google/LinkedIn/Facebook sections.
#
# NOTE: In development mode with DEBUG=True, if EMAIL_HOST_USER/PASSWORD
# are empty, REQUIRE_EMAIL_VERIFICATION is automatically disabled so you
# can log in without email setup.
# ============================================

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME="Event Management System"
APP_VERSION="1.0.0"
DEBUG=True
API_PREFIX="/api/v1"

# Frontend URL (used in email verification links, OAuth callbacks, etc.)
# Change to your frontend domain in production
FRONTEND_URL="http://localhost:8000"

# ============================================
# DATABASE CONFIGURATION
# ============================================
# For SQLite (development - no setup needed):
DATABASE_URL="sqlite:///./event_management.db"
# For PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@localhost/event_management"
SQLALCHEMY_ECHO=False

# ============================================
# JWT AUTHENTICATION - REQUIRED!
# ============================================
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Or let setup.py do it for you:   python setup.py
# Minimum 32 characters required for production
SECRET_KEY="change-me-to-a-random-secret-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# SERVER CONFIGURATION
# ============================================
HOST="0.0.0.0"
PORT=8000

# ============================================
# DEFAULT ADMIN USER (CREATED ON FIRST RUN)
# ============================================
# CHANGE THESE IN PRODUCTION!
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin@1234"
ADMIN_FIRST_NAME="Super"
ADMIN_LAST_NAME="Admin"

# ============================================
# EMAIL CONFIGURATION (SMTP / GMAIL)
# ============================================
# Leave these empty if you don't need email features.
# The app will automatically disable email verification in dev mode.
#
# For Gmail, you MUST use an App Password (not your regular password):
#   1. Enable 2-factor authentication at https://myaccount.google.com/
#   2. Generate an App Password:  https://myaccount.google.com/apppasswords
#   3. Copy the 16-character password below
DEFAULT_FROM_EMAIL=""
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=""
EMAIL_HOST_PASSWORD=""
EMAIL_PROVIDER="smtp"

# Alternative: Postmark (uncomment to use instead of SMTP)
# EMAIL_PROVIDER="postmark"
# POSTMARK_API_TOKEN="your-postmark-api-token"

# ============================================
# EMAIL VERIFICATION SETTINGS
# ============================================
VERIFICATION_TOKEN_EXPIRE_MINUTES=1440  # 24 hours
REQUIRE_EMAIL_VERIFICATION=True
# NOTE: In dev mode (DEBUG=True) with empty SMTP credentials,
# this is automatically set to False so you can log in.

# ============================================
# PASSWORD RESET SETTINGS
# ============================================
RESET_TOKEN_EXPIRE_MINUTES=30

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
UPLOAD_DIR="uploads"
MAX_IMAGE_SIZE_MB=5
ALLOWED_IMAGE_EXTENSIONS=[".jpg", ".jpeg", ".png", ".gif", ".webp"]

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================
# Get your credentials from: https://console.cloud.google.com/
# 1. Create a project → "APIs & Services" → "Credentials"
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: http://localhost:8000/api/v1/auth/google/callback
# Leave empty to disable Google login
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/google/callback"

# ============================================
# LINKEDIN OAUTH CONFIGURATION
# ============================================
# Get your credentials from: https://developer.linkedin.com/
# Leave empty to disable LinkedIn login
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="http://localhost:8000/api/v1/auth/linkedin/callback"

# ============================================
# FACEBOOK OAUTH CONFIGURATION
# ============================================
# Get your credentials from: https://developers.facebook.com/
# Leave empty to disable Facebook login
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
FACEBOOK_REDIRECT_URI="http://localhost:8000/api/v1/auth/facebook/callback"

# ============================================
# PRODUCTION ONLY - SECURITY
# ============================================
# Uncomment and set to False when deploying to production
# DEBUG=False

# ============================================
# NOTIFICATION PREFERENCES (OPTIONAL)
# ============================================
# Default user notification settings
# NOTIFICATION_EMAIL_ENABLED=True
# NOTIFICATION_SMS_ENABLED=False
# NOTIFICATION_PUSH_ENABLED=False

# ============================================
# RATE LIMITING (OPTIONAL)
# ============================================
# RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_PER_HOUR=1000

# ============================================
# LOGGING (OPTIONAL)
# ============================================
# LOG_LEVEL="INFO"
# LOG_FILE="logs/app.log"

# ============================================
# PAYMENT GATEWAY (PLACEHOLDER FOR FUTURE)
# ============================================
# STRIPE_API_KEY="your-stripe-api-key"
# STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"
# PAYPAL_CLIENT_ID="your-paypal-client-id"
# PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
